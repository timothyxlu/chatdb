# ── Dependencies ────────────────────────────────────────────────────────────
# Installed fresh inside the image; the host copy may be for a different OS/arch.
node_modules

# ── Build output ─────────────────────────────────────────────────────────────
.next
.open-next

# ── Local database files ─────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Secrets — never bake into the image ─────────────────────────────────────
.env.local
.env.*.local
.dev.vars

# ── Version control ──────────────────────────────────────────────────────────
.git
.gitignore

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
